# Required for authenticated deployments. Format:
# key1:admin:alice,key2:analyst:bob,key3:viewer:eve
RISKINTEL_API_KEYS=replace_me_admin_key:admin:alice,replace_me_analyst_key:analyst:bob

# Set to false only for isolated local debugging.
RISKINTEL_ENFORCE_AUTH=true

# Optional fallback key for trusted internal UI calls.
RISKINTEL_DEFAULT_API_KEY=

# Enable live feed lookups by default when keys are present.
RISKINTEL_USE_LIVE_FEEDS=true

# Optional writable data directory. On Vercel this defaults to /tmp/riskintel.
RISKINTEL_DATA_DIR=/tmp/riskintel

# Canonical feed keys
RISKINTEL_OTX_API_KEY=your_otx_api_key
RISKINTEL_ABUSEIPDB_API_KEY=your_abuseipdb_api_key
RISKINTEL_VT_API_KEY=your_virustotal_api_key
RISKINTEL_SHODAN_API_KEY=your_shodan_api_key
RISKINTEL_URLSCAN_API_KEY=your_urlscan_api_key

# Optional aliases supported by the codebase
OTX_API_KEY=
ABUSEIPDB_API_KEY=
VIRUSTOTAL_API_KEY=
SHODAN_API_KEY=
URLSCAN_API_KEY=
